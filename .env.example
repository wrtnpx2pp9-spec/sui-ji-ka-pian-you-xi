# Local SQLite database used by Prisma tooling.
DATABASE_URL="file:./dev.db"

# Local development value. Replace before any public deployment.
PLAYER_ACCESS_KEY="dev-access-key"

# Local development value. Replace with a long random value in production.
MIAOMI_SESSION_SECRET="miaomi-local-session-secret-change-before-production"

# Optional OpenAI-compatible or custom chat-completion endpoint.
MODEL_API_URL=""
MODEL_API_KEY=""
