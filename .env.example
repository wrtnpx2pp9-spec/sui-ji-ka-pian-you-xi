# Local SQLite database used by Prisma tooling.
DATABASE_URL="file:./dev.db"

# Required in production. Local development falls back to dev-access-key.
PLAYER_ACCESS_KEY="replace-with-a-strong-player-access-key"

# Required in production. Use a long random value to sign creator sessions.
MIAOMI_SESSION_SECRET="replace-with-a-long-random-session-secret"

# Optional OpenAI-compatible or custom chat-completion endpoint.
MODEL_API_URL=""
MODEL_API_KEY=""
