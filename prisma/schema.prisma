generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Script {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  subtitle         String?
  description      String
  theme            String
  style            String
  tagsJson         String   @default("[]")
  targetAudience   String?
  contentWarning   String?
  accessPassword   String?
  status           String   @default("draft")
  coverAssetId     String?
  estimatedMinutes Int      @default(15)
  version          Int      @default(1)
  isPublished      Boolean  @default(false)
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  planning   ScriptPlanning?
  characters Character[]
  assets     Asset[]
  stats      StoryStat[]
  nodes      StoryNode[]
  choices    StoryChoice[]
  endings    Ending[]
  aiJobs     AiJob[]
  sessions   PlaySession[]
}

model ScriptPlanning {
  id                String   @id @default(cuid())
  scriptId          String   @unique
  logline           String
  background        String
  meaning           String
  playerGoal        String
  mainConflict      String
  tone              String
  safetyBoundary    String
  forbiddenContent  String
  nodeCountTarget   Int      @default(12)
  endingCountTarget Int      @default(4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model Character {
  id                         String   @id @default(cuid())
  scriptId                   String
  key                        String
  name                       String
  roleType                   String
  description                String
  personality                String
  relationshipToProtagonist  String?
  narrativeFunction          String
  safetyNotes                String?
  defaultAssetId             String?
  sortOrder                  Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([scriptId, key])
}

model Asset {
  id             String   @id @default(cuid())
  scriptId       String
  characterId    String?
  type           String
  key            String
  name           String
  description    String?
  fileUrl        String
  thumbnailUrl   String?
  emotion        String?
  pose           String?
  sceneKey       String?
  styleTagsJson  String   @default("[]")
  prompt         String?
  negativePrompt String?
  source         String   @default("manual_upload")
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  script    Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  nodes     StoryNode[]

  @@unique([scriptId, key])
}

model StoryStat {
  id                String @id @default(cuid())
  scriptId          String
  key               String
  name              String
  description       String
  minValue          Int    @default(0)
  maxValue          Int    @default(100)
  initialValue      Int    @default(50)
  isVisibleToPlayer Boolean @default(true)
  sortOrder         Int    @default(0)

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, key])
}

model StoryNode {
  id                  String   @id @default(cuid())
  scriptId            String
  key                 String
  title               String
  nodeType            String
  chapter             String?
  summary             String
  goal                String
  tone                String
  mustIncludeJson     String   @default("[]")
  forbiddenJson       String   @default("[]")
  backgroundAssetId   String?
  characterBindingsJson String @default("[]")
  propAssetIdsJson    String   @default("[]")
  statDeltaJson       String   @default("{}")
  entryConditionJson  String   @default("{}")
  aiPrompt            String?
  generatedNarration  String?
  generatedDialoguesJson String @default("[]")
  isLocked            Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  script          Script        @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  backgroundAsset Asset?        @relation(fields: [backgroundAssetId], references: [id], onDelete: SetNull)
  choices         StoryChoice[] @relation("NodeChoices")
  incomingChoices StoryChoice[] @relation("ChoiceNextNode")
  endings         Ending[]
  aiJobs          AiJob[]
  sessions        PlaySession[]
  events          PlayEvent[]

  @@unique([scriptId, key])
}

model StoryChoice {
  id             String   @id @default(cuid())
  scriptId       String
  nodeId         String
  text           String
  description    String?
  nextNodeId     String?
  statDeltaJson  String   @default("{}")
  conditionJson  String   @default("{}")
  isKeyChoice    Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  script   Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  node     StoryNode  @relation("NodeChoices", fields: [nodeId], references: [id], onDelete: Cascade)
  nextNode StoryNode? @relation("ChoiceNextNode", fields: [nextNodeId], references: [id], onDelete: SetNull)
  events   PlayEvent[]
}

model Ending {
  id          String   @id @default(cuid())
  scriptId    String
  nodeId      String?
  key         String
  title       String
  description String
  endingType  String
  conditionJson String @default("{}")
  rank        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  script  Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  node    StoryNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  sessions PlaySession[]

  @@unique([scriptId, key])
}

model AiJob {
  id             String   @id @default(cuid())
  scriptId       String
  nodeId         String?
  jobType        String
  status         String   @default("pending")
  inputJson      String   @default("{}")
  outputJson     String   @default("{}")
  errorMessage   String?
  model          String?
  tokenInput     Int?
  tokenOutput    Int?
  costEstimate   Float?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?

  script Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  node   StoryNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
}

model PlaySession {
  id              String   @id @default(cuid())
  scriptId        String
  userId          String?
  currentNodeId   String?
  status          String   @default("playing")
  statsJson       String   @default("{}")
  visitedNodeIdsJson String @default("[]")
  unlockedEndingId String?
  startedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  endedAt         DateTime?

  script        Script     @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  currentNode   StoryNode? @relation(fields: [currentNodeId], references: [id], onDelete: SetNull)
  unlockedEnding Ending?   @relation(fields: [unlockedEndingId], references: [id], onDelete: SetNull)
  events        PlayEvent[]
}

model PlayEvent {
  id                     String   @id @default(cuid())
  sessionId              String
  nodeId                 String?
  choiceId               String?
  eventType              String
  statsBeforeJson        String   @default("{}")
  statsAfterJson         String   @default("{}")
  renderedNarration      String?
  renderedDialoguesJson  String   @default("[]")
  createdAt              DateTime @default(now())

  session PlaySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  node    StoryNode?   @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  choice  StoryChoice? @relation(fields: [choiceId], references: [id], onDelete: SetNull)
}
